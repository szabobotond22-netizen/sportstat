PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sportstat
JWT_SECRET=change_me_to_a_long_random_secret
EMAIL_MODE=dev

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=SportStat <you@example.com>

# Development helpers
ENABLE_DEV_EMAIL_LOG=true
DEV_EXPOSE_EMAIL_CODES=true
